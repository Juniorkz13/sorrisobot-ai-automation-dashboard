    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\n// O n8n às vezes entrega a resposta do HTTP Request como objeto,\n// e às vezes como array com um objeto dentro.\nconst data = Array.isArray(item) ? item[0] : item;\n\nconst responseText =\n  data?.candidates?.[0]?.content?.parts\n    ?.map(part => part.text ?? '')\n    .join('\\n')\n    .trim();\n\nconst fallback =\n  'Olá! Sou o SorrisoBot AI da Clínica Sorriso Vivo. Recebi sua mensagem e vou te ajudar. Você deseja agendar uma consulta, tirar uma dúvida ou solicitar um orçamento?';\n\nreturn [\n  {\n    json: {\n      responseText: responseText || fallback,\n      generatedAt: new Date().toISOString(),\n      model: data?.modelVersion ?? 'gemini-2.5-flash',\n      responseId: data?.responseId ?? null,\n      usageMetadata: data?.usageMetadata ?? null\n    }\n  }\n];"
      },
