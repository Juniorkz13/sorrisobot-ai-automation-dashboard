        "jsonBody": "={\n  \"conversation_id\": \"{{ $('Supabase - Get Or Create Conversation').first().json.id }}\",\n  \"contact_id\": \"{{ $('Supabase - Upsert Contact').first().json.id }}\",\n  \"direction\": \"inbound\",\n  \"type\": \"text\",\n  \"intent\": \"desconhecida\",\n  \"sentiment\": \"neutro\",\n  \"provider\": \"evolution_api\",\n  \"provider_message_id\": \"{{ $('Normalize Evolution Payload').first().json.providerMessageId }}\",\n  \"content\": \"{{ $('Normalize Evolution Payload').first().json.text }}\",\n  \"raw_payload\": {{ JSON.stringify($('Normalize Evolution Payload').first().json.rawPayload) }},\n  \"metadata\": {\n    \"instance\": \"{{ $('Normalize Evolution Payload').first().json.instance }}\",\n    \"remote_jid\": \"{{ $('Normalize Evolution Payload').first().json.remoteJid }}\"\n  }\n}",
