    {
      "parameters": {
        "jsCode": "const body = $json.body ?? $json;\n\nconst event = body.event ?? body.type ?? null;\nconst instance = body.instance ?? body.instanceName ?? 'sorrisobot';\nconst data = body.data ?? body;\n\nconst key = data.key ?? {};\nconst message = data.message ?? {};\nconst pushName = data.pushName ?? data.pushname ?? data.senderName ?? null;\n\nconst fromMe = Boolean(key.fromMe);\nconst remoteJid = key.remoteJid ?? data.remoteJid ?? data.from ?? null;\nconst providerMessageId = key.id ?? data.id ?? data.messageId ?? null;\n\nconst text =\n  message?.conversation ??\n  message?.extendedTextMessage?.text ??\n  data?.text ??\n  data?.message?.text ??\n  '';\n\nconst phoneRaw = String(remoteJid ?? '')\n  .replace('@s.whatsapp.net', '')\n  .replace('@c.us', '')\n  .replace(/\\D/g, '');\n\nconst phoneE164 = phoneRaw ? `+${phoneRaw}` : null;\n\nlet messageType = 'unknown';\n\nif (text) {\n  messageType = 'text';\n} else if (message?.imageMessage) {\n  messageType = 'image';\n} else if (message?.audioMessage) {\n  messageType = 'audio';\n} else if (message?.documentMessage) {\n  messageType = 'document';\n} else if (message?.videoMessage) {\n  messageType = 'video';\n} else if (message?.stickerMessage) {\n  messageType = 'sticker';\n}\n\nreturn [\n  {\n    json: {\n      event,\n      instance,\n      fromMe,\n      remoteJid,\n      phoneRaw,\n      phoneE164,\n      pushName,\n      providerMessageId,\n      messageType,\n      text,\n      rawPayload: body,\n      receivedAt: new Date().toISOString(),\n      isInbound: !fromMe,\n      isText: messageType === 'text',\n      shouldProcess: !fromMe && messageType === 'text' && Boolean(text)\n    }\n  }\n];"
      },
