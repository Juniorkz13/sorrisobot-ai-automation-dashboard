SERVER_URL=http://localhost:8080
EVOLUTION_API_PORT=8080
EVOLUTION_API_IMAGE=evoapicloud/evolution-api:v2.3.7
AUTHENTICATION_API_KEY=change-me-strong-api-key
EVOLUTION_INSTANCE_NAME=sorrisobot

# Banco interno da Evolution API
POSTGRES_USER=evolution
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=evolution
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:change-me-postgres-password@postgres:5432/evolution

# Redis interno da Evolution API
REDIS_PASSWORD=change-me-redis-password
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://:change-me-redis-password@redis:6379/0

# Webhook para n8n Cloud
N8N_WEBHOOK_URL=
WEBHOOK_ENABLED=true

# Configuracoes gerais
LOG_LEVEL=info

# QR Code / Baileys session
QRCODE_LIMIT=30
QRCODE_COLOR="#198754"
CONFIG_SESSION_PHONE_CLIENT="Chrome"
CONFIG_SESSION_PHONE_NAME="SorrisoBot AI"
CONFIG_SESSION_PHONE_VERSION="2.3000.1023204200"
WEB_VERSION="2.3000.1023204200"

# QR/pairing stability settings
CACHE_REDIS_ENABLED=false
CACHE_LOCAL_ENABLED=true
DATABASE_SAVE_DATA_CHATS=false
DATABASE_SAVE_DATA_CONTACTS=false
DATABASE_SAVE_DATA_HISTORIC=false
DATABASE_SAVE_DATA_LABELS=false
